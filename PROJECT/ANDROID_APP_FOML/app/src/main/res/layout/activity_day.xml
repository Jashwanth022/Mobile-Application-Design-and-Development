<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/next_day"
            android:textColor="?attr/colorOnBackground"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@string/search_icon_desc"
            app:tint="?attr/colorOnBackground" />
    </LinearLayout>

    <!-- Search Bar (Initially Hidden) -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_search_bar"
        android:hint="@string/search_stocks"
        android:padding="12dp"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOnSurface"
        android:alpha="0.7"
        android:visibility="gone"
        android:singleLine="true"
        android:inputType="text"
        android:autofillHints="name"
        android:imeOptions="actionSearch"/>

    <!-- Top Pick Section (Always Visible) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/top_pick_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOP PICK"
                android:textColor="@color/white"
                android:alpha="0.7"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/tvTopStockName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MUTHOOTFIN.NS"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:fontFamily="serif" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvTopStockChange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+1.68%"
                    android:textColor="@color/positive_green"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvTopStockAccuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="61% Accuracy"
                    android:textColor="@color/white"
                    android:alpha="0.7"
                    android:textSize="14sp"
                    android:fontFamily="serif" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tab System -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/android:colorBackground"
        app:tabTextColor="?attr/colorOnSurface"
        app:tabSelectedTextColor="?attr/colorPrimary"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabMode="fixed">
        <com.google.android.material.tabs.TabItem android:text="Overview" />
        <com.google.android.material.tabs.TabItem android:text="Chart" />
        <com.google.android.material.tabs.TabItem android:text="Details" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <!-- Overview: RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStocks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:clipToPadding="false"
            android:paddingBottom="20dp" />

        <!-- Chart: MPAndroidChart -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:visibility="gone" />

        <!-- Details: Dummy Info -->
        <ScrollView
            android:id="@+id/detailsContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="StockVision AI Analysis:\n\nOur models suggest a bullish trend for the selected period. Factors including moving averages, RSI, and sentiment analysis indicate high probability of positive momentum.\n\nNote: Predictions are generated by an experimental AI model. Market conditions can change rapidly. Always perform your own research before investing."
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.8"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="serif" />
        </ScrollView>

    </FrameLayout>

</LinearLayout>
